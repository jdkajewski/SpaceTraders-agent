# ─────────────────────────────────────────────────────────────────────────────
# deploy/bot.env.example — operator launch profile for the `bot` service (EXAMPLE).
#
# Copy to `deploy/bot.env` and edit to run the bot LIVE under docker compose:
#     cp deploy/bot.env.example deploy/bot.env
#     # paste your real token, set DRY_RUN=0, then:
#     docker compose up --build
#
# docker-compose.yml loads ./deploy/bot.env if present (env_file required:false). With NO
# bot.env the bot defaults to DRY_RUN=1 — it never calls the live SpaceTraders game API and
# needs no token, so `docker compose up` smoke-tests the full stack out of the box.
#
# These are EXAMPLE values reproducing the legacy live launch profile
# (`overnight_experiment.sh` ENVLINE). They are NOT defaults baked into the code — the bot's
# only config source is `loadConfig(process.env)` in @st/shared; unset flags use code defaults.
# ─────────────────────────────────────────────────────────────────────────────

# ── connection / identity ────────────────────────────────────────────────────
SPACETRADERS_PLAYER_AGENT_TOKEN=PASTE_YOUR_AGENT_TOKEN_HERE
API_BASE_URL=http://api:3000
BOT_KEY=
SYSTEM=X1-PP30

# ── DRY_RUN switch ───────────────────────────────────────────────────────────
# 1 = offline smoke (no live game calls, no token needed). Set to 0 for a real run.
DRY_RUN=0
DRY_RUN_CREDITS=250000

# ── live earner profile (legacy overnight_experiment.sh ENVLINE) ─────────────
MIN_NET=1200
CONTRACT_MIN_MARGIN_PCT=0.04
GATE_SUPPLY=1
GATE_CREDIT_FLOOR=900000
GATE_CREDIT_RESUME_GAP=250000
GATE_HAULERS=12,13
GATE_MAX_SUPPLIERS=2
GATE_MAX_PRICE=FAB_MATS:3900,ADVANCED_CIRCUITRY:12500
GATE_PROTECT=1
CONTRACT_AVOID_GATE_PRODUCER=1
CONTRACT_BEST_SHIP=1
INPUT_FEED=0
MINE_FEED=1
MINE_TRANSPORT=14,29
MINE_FUNNEL=28
MINE_BATCH=30
MINE_FUEL_RESERVE=20
MINE_ORE_RESERVE=0
MINE_CLOG_AT=0
FILL_BIAS=1
FILL_BIAS_EPS=0.10
DEBUG_CONTRACT=1

# ── inter-system expansion (Wave 5; default OFF — uncomment to arm YOLO mode) ──
# AUTO_EXPAND=1
# EXPAND_CREDIT_FLOOR=400000
# EXPAND_AUTOBUY=1
# EXPAND_BUY_FLOOR=700000
# EXPAND_MAX_BUY_TRADERS=8
# EXPAND_MAX_BUY_PROBES=40
# EXPAND_OUTPOST_PROBES=4
# EXPAND_OUTPOST_TRADERS=4
# EXPAND_SCAN_TTL_MS=240000
