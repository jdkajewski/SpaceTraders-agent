// SpaceTraders Agent — Prisma schema
// All models map to bot2.mjs file artifacts (MASTER-PLAN §3).

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
  // Emit query-engine binaries for both the host (native) and the linux-musl Docker runtime
  // (node:20-alpine, OpenSSL 3) so the API image works on amd64 and arm64. (DRIFT #34)
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Singleton: run statistics (crash-safe, persisted across restarts) ─────────
// Mirrors run-stats.json. Always a single row with id = 1.
model RunStats {
  id         Int      @id @default(1)
  totalNet   Float    @default(0)
  lanesRun   Int      @default(0)
  updatedAt  DateTime @updatedAt
}

// ── Per-ship intents (crash-safe, in-flight cargo intents) ────────────────────
// Mirrors intents.json. PK is the ship symbol.
model Intent {
  shipSym    String   @id
  phase      String
  good       String
  units      Int
  buyWp      String
  sellWp     String
  costBasis  Float
  extras     Json?
  updatedAt  DateTime @updatedAt
}

// ── Status snapshots (latest + history) ──────────────────────────────────────
// Mirrors bot-status.json. Denormalized columns allow efficient querying;
// the full snapshot lives in the `data` JSON column.
model StatusSnapshot {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  phase     String
  runNet    Float
  credits   Float
  gate      String?  // "BUILT" | "UNBUILT" | null
  data      Json

  @@index([createdAt])
}

// ── Market snapshots (latest per waypoint) ────────────────────────────────────
// Mirrors markets.json. PK is the waypoint symbol.
model MarketSnapshot {
  waypoint  String   @id
  data      Json
  updatedAt DateTime @updatedAt
}

// ── Market history (append-only time series) ─────────────────────────────────
// Mirrors market-history.jsonl.
model MarketHistory {
  id           String   @id @default(cuid())
  ts           DateTime @default(now())
  waypoint     String
  good         String
  purchasePrice Float
  sellPrice    Float
  tradeVolume  Int
  supply       String
  activity     String?

  @@index([ts])
  @@index([waypoint])
  @@index([good])
}

// ── Trade observations (append-only) ─────────────────────────────────────────
// Mirrors trade-observations.jsonl.
model TradeObservation {
  id         String   @id @default(cuid())
  ts         DateTime @default(now())
  shipSym    String
  good       String
  buyWp      String
  sellWp     String
  projected  Float
  realized   Float
  units      Int
  buyPx      Float
  sellPx     Float

  @@index([ts])
  @@index([shipSym])
}

// ── Mine events (append-only) ────────────────────────────────────────────────
// Mirrors mine-history.jsonl. type = extract | refine | survey | feed
model MineEvent {
  id      String   @id @default(cuid())
  ts      DateTime @default(now())
  type    String
  shipSym String
  data    Json

  @@index([ts])
  @@index([shipSym])
}

// ── GateLevers singleton (operator control input) ────────────────────────────
// Mirrors gate-levers.json. Always a single row with id = 1.
// Operators PUT /gate-levers; bot polls GET /gate-levers.
model GateLevers {
  id             Int      @id @default(1)
  floor          Float    @default(1500000)
  resume         Float    @default(1750000)
  gap            Float    @default(250000)
  budgetFraction Float    @default(0.8)
  updatedAt      DateTime @updatedAt
}

// ── Waypoints (seeded from coords.csv, read-mostly) ─────────────────────────
// PK is the waypoint symbol (e.g. "X1-PP30-A1").
model Waypoint {
  symbol String @id
  x      Float
  y      Float
}

// ── FuelNodes cache (optional, derived — may remain in-memory) ───────────────
model FuelNode {
  symbol    String   @id
  systemSym String
  updatedAt DateTime @updatedAt
}

// ── Galaxy map: systems (nodes), gate edges, market richness ─────────────────
// Produced by the home-rooted BFS galaxy crawler (packages/bot/src/galaxy). The
// bot preloads this for an unbounded gate-path pathfinder + ranked AUTO_EXPAND
// targets; the visualization reads it directly. Upserted incrementally so a crawl
// is crash-resumable.

/// A star system node in the gate graph. PK is the system symbol (e.g. "X1-DB23").
model System {
  symbol              String    @id
  x                   Float? // system coords (when known)
  y                   Float?
  hasGate             Boolean   @default(false)
  gateWaypoint        String? // the JUMP_GATE waypoint symbol, when present
  gateBuilt           Boolean   @default(false) // !isUnderConstruction (can jump in/out)
  hopsFromHome        Int? // BFS depth over traversable gates from home
  reachable           Boolean   @default(false) // an all-built gate path exists from home
  isHome              Boolean   @default(false)
  firstSeenAt         DateTime  @default(now())
  lastCrawledAt       DateTime  @updatedAt
  richnessRefreshedAt DateTime? // last time the (expensive) full richness pass ran
  edgesOut            GateEdge[] @relation("edgesOut")
  edgesIn             GateEdge[] @relation("edgesIn")
  richness            SystemRichness?

  @@index([reachable])
  @@index([hopsFromHome])
  @@index([lastCrawledAt])
}

/// A directed jump-gate connection. Built-state is per-gate, so we track both ends.
model GateEdge {
  id          String   @id @default(cuid())
  fromSystem  String
  toSystem    String
  fromGateWp  String?
  toGateWp    String?
  builtFrom   Boolean  @default(false) // source gate built (can jump OUT)
  builtTo     Boolean  @default(false) // dest gate built (can jump IN)
  traversable Boolean  @default(false) // builtFrom && builtTo
  updatedAt   DateTime @updatedAt
  from        System   @relation("edgesOut", fields: [fromSystem], references: [symbol], onDelete: Cascade)
  to          System   @relation("edgesIn", fields: [toSystem], references: [symbol], onDelete: Cascade)

  @@unique([fromSystem, toSystem])
  @@index([fromSystem])
  @@index([toSystem])
  @@index([traversable])
}

/// Per-system market richness metrics + the computed expansion rank.
model SystemRichness {
  systemSym        String   @id
  marketplaceCount Int      @default(0)
  shipyardCount    Int      @default(0)
  importSiteCount  Int      @default(0) // # markets importing tradeable goods
  importGoodsTotal Int      @default(0) // total distinct import goods across markets
  premiumShipTypes String[] // EXPLORER, HEAVY_FREIGHTER, REFINING_FREIGHTER, ORE_HOUND, COMMAND_FRIGATE, LIGHT_HAULER
  premiumShipCount Int      @default(0)
  sellsFueledHull  Boolean  @default(false) // a shipyard here sells a fueled hull (buy local vs relay)
  score            Float    @default(0) // computed ranking score
  detailLevel      String   @default("counts") // "counts" (cheap) | "full" (markets+shipyards read)
  updatedAt        DateTime @updatedAt
  system           System   @relation(fields: [systemSym], references: [symbol], onDelete: Cascade)

  @@index([score])
}
