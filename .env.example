# ============================================================
# SpaceTraders Agent — environment variables
# Copy to .env and fill in real values.
# ============================================================

# ── Infrastructure ───────────────────────────────────────────
DATABASE_URL="postgresql://st:st@localhost:5432/st?schema=public"
ST_TOKEN="your-spacetraders-token-here"
API_PORT=3000
API_BASE_URL="http://localhost:3000"

# ── Core trade ───────────────────────────────────────────────
SYSTEM=X1-PP30
MAXD=2000
MIN_NET=4000
VALUE_OF_TIME=100
COOLDOWN_MS=300000
COOLDOWN_FLOOR_MS=60000
COOLDOWN_MIN_MULT=0.33
COOLDOWN_MAX_MULT=4
DEAD_LANE_PENALTY=3
PARK_MIN_NET=0
SPEED_FAR_DIST=250

# ── Ride-along / multi-good ───────────────────────────────────
# MULTI_GOOD=0                  # default ON; set 0 to disable
RIDEALONG_MIN_GROSS=1000
# CONTRACT_RIDEALONG=0          # default ON; set 0 to disable

# ── Fill-bias ────────────────────────────────────────────────
# FILL_BIAS=0                   # default ON; set 0 to disable
FILL_BIAS_EPS=0.10
GATE_DROPOFF_WEIGHT=0.5

# ── Phase / budget ───────────────────────────────────────────
BOOTSTRAP_FLEET_MIN=2
CREDIT_TARGET=0
SLIPPAGE_FACTOR=1.5
GOODS_CUSHION=300000
GOODS_CUSHION_PER_SHIP=25000
RESERVE_CONCURRENCY=3
OPERATING_RESERVE=200000
NEW_CELL_SEED=600000
HAULER_PRICE=314345

# ── Contracts ────────────────────────────────────────────────
# CONTRACTS=0                   # default ON; set 0 to disable
# TRADE_FIRST=1                 # default OFF; set 1 to enable
# CONTRACT_AVOID_GATE_PRODUCER=0  # default ON
# CONTRACT_BEST_SHIP=0          # default ON
# CONTRACT_RIDEALONG=0          # default ON
CONTRACT_MIN_MARGIN=1000
CONTRACT_MIN_MARGIN_PCT=0.04
CONTRACT_MAX_SRC_DIST=500
CONTRACT_FUEL_PX=2
CONTRACT_MAX_HOPS=6
CONTRACT_AUTOFORCE_MINS=20
CONTRACT_REELECT_MARGIN=40
# CONTRACT_RUNNER=             # comma-sep ship suffixes for dedicated runner
# CONTRACT_FORCE=              # comma-sep goods to force-contract
# DEBUG_CONTRACT=1             # verbose contract decisions
NEGOTIATOR=SPACEJAM-DK-2-15

# ── Gate supply ───────────────────────────────────────────────
# GATE_SUPPLY=0                 # default ON
GATE_CREDIT_FLOOR=1500000
GATE_CREDIT_RESUME_GAP=250000
# GATE_CREDIT_RESUME=          # default = FLOOR+GAP
GATE_SUPPLY_MAX_UNITS=0
GATE_MAX_SUPPLIERS=2
GATE_PRICE_CEIL_FACTOR=2.0
GATE_PRICE_SETTLE_MS=240000
GATE_PRICE_REBOUND_EPS=0.02
# GATE_MAX_PRICE=FAB_MATS:3200,ADVANCED_CIRCUITRY:7000
# Gate price hysteresis (anti-sawtooth): pause buys when a material exceeds GATE_MAX_PRICE; don't resume until it
# cools to GATE_RESUME_PRICE (explicit per-material floor) or GATE_MAX_PRICE × GATE_RESUME_PRICE_FACTOR if unset.
# GATE_RESUME_PRICE=FAB_MATS:2900,ADVANCED_CIRCUITRY:6300
GATE_RESUME_PRICE_FACTOR=0.9
# Fraction of free growth budget the gate may spend per pass (rest stays liquid for the trade/contract/feed earners).
# Clamped [0,1]; live-tunable via the gate-levers control input (budgetFraction).
GATE_BUDGET_FRACTION=0.8
# GATE_PROTECT=0               # default ON
GATE_PROTECT_MATERIALS=FAB_MATS,ADVANCED_CIRCUITRY,QUANTUM_STABILIZERS
# GATE_FUEL_CARGO=1            # default OFF
# GATE_HAULERS=                # comma-sep ship suffixes for dedicated haulers
GATE_DROPOFF_WEIGHT=0.5
# ORPHAN_GATE_DELIVERY=0       # default ON
ORPHAN_MIN_UNITS=5

# ── Input feed ───────────────────────────────────────────────
# INPUT_FEED=1                  # default OFF
INPUT_FEED_MAX=2
INPUT_FEED_MIN_GROSS=0
# INPUT_FEED_GATE_PAUSE=1      # default OFF (independent of gate pause)
INPUT_FEED_MIN_CASH=0
# INPUT_FEEDERS=               # comma-sep dedicated feeder ship suffixes
FEED_FOCUS_MATERIALS=FAB_MATS
# Materials whose producers' inputs get RESERVED out of non-feed trades (separate from FEED_FOCUS so we can feed a
# material without locking its fat-lane inputs). Default FAB_MATS only.
FEED_RESERVE_MATERIALS=FAB_MATS
FEED_MAX_LOSS_PER_UNIT=30
# FEED_RESERVE_INPUTS=0        # default ON
# FEED_SECOND_LEVEL=0          # default ON — also feed the sub-producers of a gate producer's SCARCE/LIMITED inputs
# FEED_MAX_PRICE=IRON:160,QUARTZ_SAND:40
FEED_PRICE_SETTLE_MS=240000
FEED_PRICE_REBOUND_EPS=0.02

# ── Mining ───────────────────────────────────────────────────
# MINE_FEED=1                   # default OFF
# MINE_FEEDERS=                 # comma-sep dedicated miner-feeder suffixes
MINE_GOOD=
MINE_BATCH=24
MINE_PRODUCER=
# MINE_TRANSPORT=              # comma-sep tender ship suffixes
MINE_FUEL_RESERVE=12
# MINE_FUNNEL=                 # comma-sep funnel ship suffixes
MINE_CLOG_AT=32
MINE_ORE_RESERVE=30
# MINE_RAW_RELIEF=0            # default ON

# ── Repair ───────────────────────────────────────────────────
# REPAIR=1                      # default OFF
REPAIR_COND_MIN=0.85
REPAIR_INTEG_FORCE=0.5
REPAIR_MAX_COST=100000

# ── Fleet scale ───────────────────────────────────────────────
# FLEET_SCALE=1                 # default OFF
FLEET_SCALE_FLOOR=30000
FLEET_SCALE_MS=120000
FLEET_HAULER_MIN=350000
FLEET_SHUTTLE_MIN=120000
FLEET_TARGET_TRADERS=4
FLEET_BASE_PROBES=5
FLEET_PROBE_RATIO=3
FLEET_MAX_PROBES=0
FLEET_MAX_HAULERS=6
# FLEET_TABLE=0                # default ON
FLEET_TABLE_MS=60000

# ── Mine expand / migrate ─────────────────────────────────────
# MINE_EXPAND=1                 # default OFF
MINE_MAX_SURVEYORS=3
MINE_MAX_DRONES=4
MINE_EXPAND_CREDIT_FLOOR=600000
MINE_EXPAND_SCAN_MS=600000
# MINE_MIGRATE=1               # default OFF
MINE_MIGRATE_SCAN_MS=300000

# ── Fuel cargo ───────────────────────────────────────────────
# FUEL_CARGO=1                  # default OFF

# ── Expansion ────────────────────────────────────────────────
# AUTO_EXPAND=1                 # default OFF
EXPAND_TARGET_SYSTEM=
