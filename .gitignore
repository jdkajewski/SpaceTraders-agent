# ── Secrets ───────────────────────────────────────────────
# SpaceTraders agent token — NEVER commit. Provide via env:
#   export SPACETRADERS_PLAYER_AGENT_TOKEN="..."
.tok
.tok2
.env
*.token

# ── Runtime state (regenerated by the bot at runtime) ──────
markets.json          # market snapshot — seed with `node markets.mjs <waypoints...>`
tracker.md            # live status dashboard the bot appends to
bot-status.json       # status snapshot (written each completed lane)
run-stats.json        # cumulative net/lanes (persists across restarts)
intents.json          # crash-safe in-flight cargo intents
residency.json        # per-ship system pinning (expansion)
snap*.json
cycle.json
fleet*.json

# ── History / telemetry logs (large, append-only) ─────────
*.log
*.jsonl
*.out
*.csv
!coords.csv           # static system geometry IS source input — keep it

# ── Local helper bookkeeping ──────────────────────────────
.current_log
.calib_baseline
.checkin_baseline
.colony_log
.gaterate_log
.monitor_log
STOP
STOP.hint

# ── Node ──────────────────────────────────────────────────
node_modules/

# ── TypeScript monorepo (packages/) ───────────────────────
packages/*/dist/
packages/*/tsconfig.tsbuildinfo
*.tsbuildinfo

# ── Prisma ────────────────────────────────────────────────
packages/api/src/generated/

# ── Environment ───────────────────────────────────────────
.env.local
.env.*.local
